#!/bin/sh
# Apache Maven Wrapper startup script, version 3.2.0

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(dirname "$0")}"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

if [ ! -f "$WRAPPER_JAR" ]; then
    WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
    if [ -f "$WRAPPER_PROPERTIES" ]; then
        WRAPPER_URL_FROM_PROPS=$(grep "^wrapperUrl=" "$WRAPPER_PROPERTIES" | cut -d'=' -f2-)
        if [ -n "$WRAPPER_URL_FROM_PROPS" ]; then
            WRAPPER_URL="$WRAPPER_URL_FROM_PROPS"
        fi
    fi
    echo "Downloading maven-wrapper.jar..."
    if command -v curl >/dev/null 2>&1; then
        curl -sL "$WRAPPER_URL" -o "$WRAPPER_JAR"
    elif command -v wget >/dev/null 2>&1; then
        wget -q "$WRAPPER_URL" -O "$WRAPPER_JAR"
    else
        echo "ERROR: curl or wget required to download maven-wrapper.jar" >&2
        exit 1
    fi
fi

exec "$JAVACMD" \
  $MAVEN_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
